# Google Analytics 4 measurement ID. Gets injected into next/script.
# Leave blank locally; set in Vercel production env vars for the live site.
NEXT_PUBLIC_GA_ID=

# Apple App Store ID and URL for the Inku iOS app.
# Bao will fill these in once the app is approved.
NEXT_PUBLIC_APP_STORE_ID=0000000000
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id0000000000

# The public site URL. Only override locally for preview testing.
SITE_URL=https://inkujapanese.com

# Site-verification tokens for search consoles. Leave blank until you
# register the property and pick HTML meta tag verification.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
